# Ejemplo: Nginx delante del sitio estático o del contenedor Node SSR.
# En producción con apiBaseUrl = '' el navegador llama a /api/v1/... en el mismo host;
# este bloque reenvía esas peticiones al backend ASP.NET Core.

server {
    listen 80;
    server_name tu-dominio.com;

    # Front (build estático browser/ o proxy al Node SSR en :4000)
    location / {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        proxy_pass https://api-interno:7020;
        proxy_ssl_server_name on;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
